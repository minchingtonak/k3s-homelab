#!/usr/bin/env bash
set -euo pipefail

export PATH="${AQUA_ROOT_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/aquaproj-aqua}/bin:$PATH"

# Collect all staged files
mapfile -t staged < <(git diff --cached --name-only --diff-filter=ACM || true)

if [ "${#staged[@]}" -gt 0 ]; then
    # strip ANSI control chars
    dprint check --allow-no-files "${staged[@]}" 2>&1 | sed 's/\x1b\[[0-9;]*[a-zA-Z]//g'; exit "${PIPESTATUS[0]}"
fi

# Collect staged YAML files under k8s/
mapfile -t files < <(
    printf '%s\n' "${staged[@]}" \
    | grep -E '^k8s/.*\.ya?ml$' \
    || true
)

if [ "${#files[@]}" -gt 0 ]; then
    python3 scripts/lint-k8s.py "${files[@]}"
fi
