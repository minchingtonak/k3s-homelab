{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    // helm chart versions don't use digests
    { matchManagers: ["flux"], pinDigests: false },
    // group all k3s version bumps (Plans + pulumi IaC + ansible) into one PR
    { matchDepNames: ["k3s-io/k3s"], groupName: "k3s version" },
    // group flux distribution bumps (flux-instance.yaml + ansible role) into one PR
    { matchDepNames: ["fluxcd/flux2"], groupName: "flux version" },
    // group flux-operator bumps into one PR: the github-releases pins in pulumi IaC +
    // ansible role (bootstrap) and the OCI helm chart Flux self-manages
    // (k8s/infrastructure/flux-operator). Chart tags track the GitHub releases 1:1.
    {
      matchPackageNames: ["controlplaneio-fluxcd/flux-operator", "ghcr.io/controlplaneio-fluxcd/charts/flux-operator"],
      groupName: "flux-operator version",
    },
    // group all node version bumps (CI node-version + @types/node) into one PR
    { matchDepNames: ["node", "@types/node"], groupName: "node version" },
    // helm bootstrap binary must stay on the v3 line: Flux's helm-controller uses the
    // Helm v3 release-storage format, so a v4-written release Secret breaks adoption.
    { matchDepNames: ["helm/helm"], allowedVersions: "<4" },

    { matchPackagePatterns: ["^lavaforge\\.org/"], enabled: false },
    {
      matchPackageNames: ["ghcr.io/linuxserver/jellyfin"],
      allowedVersions: "<2021",
    },
    {
      matchPackageNames: ["ghcr.io/linuxserver/nzbget"],
      allowedVersions: "<2021",
    },
    {
      matchPackageNames: ["ghcr.io/linuxserver/qbittorrent"],
      allowedVersions: "<7",
    },
    // hotio lidarr uses non-standard versioning (pr-plugins branch)
    {
      matchPackageNames: ["ghcr.io/hotio/lidarr"],
      versioning: "regex:^(?<compatibility>pr-plugins)-(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\.(?<build>\\d+)$",
      ignoreUnstable: false,
    },
    // listenarr uses non-standard versioning (canary channel)
    {
      matchPackageNames: ["ghcr.io/listenarrs/listenarr"],
      versioning: "regex:^(?<compatibility>canary)-(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$",
      ignoreUnstable: false,
    },

    // ── stateful service images ────────────────────────────────────────────
    // Each app needs a specific major of its database/cache/broker. We:
    //   1. cap the allowed major per app via allowedVersions
    //   2. group remaining minor/patch bumps and run them monthly
    //   3. require dashboard approval for any major that slips through

    // per-app major pins
    { matchFileNames: ["k8s/apps/tandoor/**"],      matchPackageNames: ["postgres"],         allowedVersions: "<17" },
    { matchFileNames: ["k8s/apps/docuseal/**"],     matchPackageNames: ["postgres"],         allowedVersions: "<16" },
    { matchFileNames: ["k8s/apps/windmill/**"],     matchPackageNames: ["postgres"],         allowedVersions: "<17" },
    { matchFileNames: ["k8s/apps/immich/**"],       matchPackageNames: ["redis"],            allowedVersions: "<7" },
    { matchFileNames: ["k8s/apps/dawarich/**"],     matchPackageNames: ["postgis/postgis"],  allowedVersions: "/^17-/" },
    { matchFileNames: ["k8s/apps/dawarich/**"],     matchPackageNames: ["redis"],            allowedVersions: "<8" },
    { matchFileNames: ["k8s/apps/fittrackee/**"],   matchPackageNames: ["postgis/postgis"],  allowedVersions: "/^17-/" },
    { matchFileNames: ["k8s/apps/your-spotify/**"], matchPackageNames: ["mongo"],            allowedVersions: "<7" },
    { matchFileNames: ["k8s/apps/paperless-ngx/**"], matchPackageNames: ["gotenberg/gotenberg"], allowedVersions: "<9" },
    { matchFileNames: ["k8s/apps/paperless-ngx/**"], matchPackageNames: ["postgres"],         allowedVersions: "<19" },
    { matchFileNames: ["k8s/apps/paperless-ngx/**"], matchPackageNames: ["redis"],            allowedVersions: "<9" },
    { matchFileNames: ["k8s/apps/forgejo/**"],      matchPackageNames: ["postgres"],         allowedVersions: "<19" },
    { matchFileNames: ["k8s/apps/spotizerr/**"],    matchPackageNames: ["redis"],            allowedVersions: "<9" },
    { matchFileNames: ["k8s/apps/audiomuse-ai/**"], matchPackageNames: ["postgres"],         allowedVersions: "<16" },
    { matchFileNames: ["k8s/apps/audiomuse-ai/**"], matchPackageNames: ["redis"],            allowedVersions: "<8"  },

    // group + slow down stateful bumps to one batched PR per category per month
    {
      matchDatasources: ["docker"],
      matchPackageNames: ["/postgres/", "/postgis/"],
      groupName: "stateful: postgres",
      schedule: ["* * 1-7 * 6"], // first Saturday of the month
    },
    {
      matchDatasources: ["docker"],
      matchPackageNames: ["/redis/", "/valkey/", "/memcached/"],
      groupName: "stateful: caches",
      schedule: ["* * 1-7 * 6"],
    },
    {
      matchDatasources: ["docker"],
      matchPackageNames: ["/mongo/", "/mariadb/", "/mysql/", "/rabbitmq/", "/gotenberg/"],
      groupName: "stateful: other",
      schedule: ["* * 1-7 * 6"],
    },

    // safety net: never auto-open a major PR for stateful images — surface on the
    // dependency dashboard so a migration is an explicit, manual decision.
    {
      matchDatasources: ["docker"],
      matchPackageNames: [
        "/postgres/",
        "/postgis/",
        "/redis/",
        "/valkey/",
        "/memcached/",
        "/mongo/",
        "/mariadb/",
        "/mysql/",
        "/rabbitmq/",
      ],
      matchUpdateTypes: ["major"],
      dependencyDashboardApproval: true,
    },

    // immich: server + ML release in lockstep on identical version tags — group
    // them so a single PR bumps both to the same version. Placed last so groupName
    // + schedule win over the "stateful: *" rules. redis is intentionally NOT here:
    // it falls into the monthly "stateful: caches" batch (capped at <7 above).
    {
      matchFileNames: ["k8s/apps/immich/**"],
      matchDatasources: ["docker"],
      matchPackageNames: ["ghcr.io/immich-app/immich-server", "ghcr.io/immich-app/immich-machine-learning"],
      groupName: "immich",
      schedule: ["on saturday"],
    },
    // immich postgres: pinned exactly to the vectorchord/pgvectors build immich
    // currently supports. Freeze it — a bump is a manual, deliberate migration.
    {
      matchFileNames: ["k8s/apps/immich/**"],
      matchPackageNames: ["ghcr.io/immich-app/postgres"],
      enabled: false,
    },
  ],
}
